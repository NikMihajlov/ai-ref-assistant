# ── Database ────────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=changeme

# ── App ─────────────────────────────────────────────────────────────────────────
APP_PORT=8080

# Public URL used for Google OAuth redirect_uri (e.g. https://yourapp.example.com)
PUBLIC_URL=https://yourapp.example.com

# ── Google OAuth ────────────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Add <PUBLIC_URL>/signin-google to Authorised redirect URIs
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── Google Calendar (optional) ──────────────────────────────────────────────────
# Service account JSON — only needed if you want server-side calendar fallback.
# The app prefers the logged-in user's OAuth token; leave blank to skip.
GOOGLE_SERVICE_ACCOUNT_JSON=
