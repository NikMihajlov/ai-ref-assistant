@page
@model Flourish.Pages.Team.TeamIndexModel
@using Flourish.Models
@{
    ViewData["Title"] = "Team Goals";
}

<div class="space-y-5">
    @* Period filter *@
    <div class="flex gap-2 flex-wrap">
        @foreach (var period in Model.Periods)
        {
            <a asp-page="/Team/Index" asp-route-periodId="@period.Id"
               class="px-3 py-1.5 rounded-lg text-xs font-medium transition-colors @(Model.SelectedPeriodId == period.Id ? "bg-accent text-surface" : "bg-panel border border-border text-muted hover:text-gray-200")">
                @period.Name
            </a>
        }
    </div>

    @foreach (var member in Model.TeamMembers)
    {
        var memberGoals = Model.GoalsByUser.GetValueOrDefault(member.Id, []);
        <div class="bg-panel border border-border rounded-xl overflow-hidden">
            <div class="px-5 py-4 border-b border-border flex items-center gap-3">
                @if (!string.IsNullOrEmpty(member.AvatarUrl))
                {
                    <img src="@member.AvatarUrl" class="w-7 h-7 rounded-full" alt="@member.Name" />
                }
                else
                {
                    <div class="w-7 h-7 rounded-full bg-accent/20 flex items-center justify-center text-accent text-xs font-bold">
                        @member.Name[0]
                    </div>
                }
                <div>
                    <p class="text-sm font-medium text-gray-200">@member.Name</p>
                    <p class="text-xs text-muted">@member.Email</p>
                </div>
                <div class="ml-auto flex items-center gap-4 text-xs text-muted">
                    @{
                        var nextReview = Model.NextReviewByUser.GetValueOrDefault(member.Id);
                    }
                    @if (nextReview is not null)
                    {
                        var days = (nextReview.ScheduledAt - DateTime.UtcNow).Days;
                        var label = days == 0 ? "Today" : days == 1 ? "Tomorrow" : $"in {days}d";
                        var labelColor = days <= 1 ? "text-amber-400" : "text-blue-400";
                        <span class="flex items-center gap-1 @labelColor">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            Review @label
                        </span>
                        @if (!string.IsNullOrEmpty(nextReview.MeetLink))
                        {
                            <a href="@nextReview.MeetLink" target="_blank"
                               class="flex items-center gap-1 text-accent hover:underline">
                                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M17 10.5V7a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h12a1 1 0 001-1v-3.5l4 4v-11l-4 4z"/></svg>
                                Join
                            </a>
                        }
                        <span class="text-border">|</span>
                    }
                    else
                    {
                        <a asp-page="/Reviews/Index" class="flex items-center gap-1 text-muted hover:text-accent transition-colors">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                            Schedule review
                        </a>
                        <span class="text-border">|</span>
                    }
                    <span class="text-accent font-medium">@memberGoals.Count(g => g.Status == GoalStatus.Completed) completed</span>
                    <span>·</span>
                    <span>@memberGoals.Count total</span>
                </div>
            </div>

            @if (memberGoals.Any())
            {
                <div class="divide-y divide-border">
                    @foreach (var goal in memberGoals)
                    {
                        <partial name="_GoalRow" model="goal" />
                    }
                </div>
            }
            else
            {
                <p class="px-5 py-4 text-sm text-muted">No goals for this period.</p>
            }
        </div>
    }
</div>
