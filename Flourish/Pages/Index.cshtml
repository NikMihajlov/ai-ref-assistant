@page
@model Flourish.Pages.IndexModel
@using Flourish.Models
@{
    ViewData["Title"] = "Dashboard";
}

<div class="space-y-6">

    @* Period header *@
    @if (Model.ActivePeriod is not null)
    {
        <div class="flex items-center justify-between">
            <div>
                <p class="text-xs text-muted uppercase tracking-widest mb-1">Active Period</p>
                <h2 class="text-xl font-semibold text-gray-100">@Model.ActivePeriod.Name</h2>
                <p class="text-sm text-muted mt-0.5">@Model.ActivePeriod.StartDate.ToString("MMM d, yyyy") — @Model.ActivePeriod.EndDate.ToString("MMM d, yyyy")</p>
            </div>
            <a asp-page="/Goals/Create" class="inline-flex items-center gap-2 bg-accent hover:bg-accent-dim text-surface font-semibold text-sm px-4 py-2 rounded-lg transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                New Goal
            </a>
        </div>
    }
    else
    {
        <div class="bg-panel border border-border rounded-xl p-6 text-center">
            <p class="text-muted text-sm">No active review period. A team lead needs to create one.</p>
        </div>
    }

    @* Stats row *@
    <div class="grid grid-cols-4 gap-4">
        @{
            var stats = new[] {
                ("Total Goals", Model.TotalGoals.ToString(), "text-gray-300"),
                ("In Progress", Model.InProgressGoals.ToString(), "text-blue-400"),
                ("At Risk", Model.AtRiskGoals.ToString(), "text-amber-400"),
                ("Completed", Model.CompletedGoals.ToString(), "text-accent"),
            };
        }
        @foreach (var (label, value, color) in stats)
        {
            <div class="bg-panel border border-border rounded-xl px-5 py-4">
                <p class="text-xs text-muted mb-1">@label</p>
                <p class="text-2xl font-bold @color">@value</p>
            </div>
        }
    </div>

    @* Upcoming reviews *@
    @if (Model.UpcomingReviews.Any())
    {
        <div class="bg-panel border border-border rounded-xl overflow-hidden">
            <div class="px-5 py-4 border-b border-border flex items-center justify-between">
                <h3 class="text-sm font-semibold text-gray-200">
                    <svg class="w-4 h-4 inline-block mr-1.5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    Upcoming Reviews
                </h3>
                <a asp-page="/Reviews/Index" class="text-xs text-muted hover:text-accent transition-colors">View all →</a>
            </div>
            <div class="divide-y divide-border">
                @foreach (var review in Model.UpcomingReviews)
                {
                    var isReviewer = review.ReviewerId == Model.CurrentUserId;
                    var otherPerson = isReviewer ? review.Reviewee?.Name : review.Reviewer?.Name;
                    var role = isReviewer ? "Conducting review for" : "Review with";
                    var daysUntil = (review.ScheduledAt - DateTime.UtcNow).Days;
                    var dueLabel = daysUntil == 0 ? "Today" : daysUntil == 1 ? "Tomorrow" : $"In {daysUntil} days";
                    var dueLabelColor = daysUntil <= 1 ? "text-amber-400" : "text-muted";
                    <div class="px-5 py-3.5 flex items-center gap-4">
                        <div class="w-10 h-10 rounded-lg bg-accent/10 border border-accent/20 flex flex-col items-center justify-center shrink-0">
                            <span class="text-xs font-bold text-accent leading-none">@review.ScheduledAt.ToString("MMM").ToUpper()</span>
                            <span class="text-sm font-bold text-accent leading-none mt-0.5">@review.ScheduledAt.Day</span>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-medium text-gray-200">@role @otherPerson</p>
                            <p class="text-xs text-muted mt-0.5">@review.ReviewPeriod?.Name · @review.ScheduledAt.ToString("h:mm tt")</p>
                        </div>
                        <div class="flex items-center gap-3 shrink-0">
                            <span class="text-xs font-medium @dueLabelColor">@dueLabel</span>
                            @if (!string.IsNullOrEmpty(review.MeetLink))
                            {
                                <a href="@review.MeetLink" target="_blank"
                                   class="inline-flex items-center gap-1.5 text-xs bg-accent/10 text-accent border border-accent/20 px-3 py-1.5 rounded-lg hover:bg-accent/20 transition-colors font-medium">
                                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M17 10.5V7a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h12a1 1 0 001-1v-3.5l4 4v-11l-4 4z"/></svg>
                                    Join Meet
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @* Goals list *@
    @if (Model.MyGoals.Any())
    {
        <div class="bg-panel border border-border rounded-xl overflow-hidden">
            <div class="px-5 py-4 border-b border-border">
                <h3 class="text-sm font-semibold text-gray-200">My Goals</h3>
            </div>
            <div class="divide-y divide-border" id="goals-list">
                @foreach (var goal in Model.MyGoals)
                {
                    <partial name="_GoalRow" model="goal" />
                }
            </div>
        </div>
    }
    else if (Model.ActivePeriod is not null)
    {
        <div class="bg-panel border border-border rounded-xl p-10 text-center">
            <p class="text-muted text-sm">No goals yet for this period.</p>
            <a asp-page="/Goals/Create" class="inline-block mt-3 text-accent text-sm hover:underline">Add your first goal →</a>
        </div>
    }

</div>
