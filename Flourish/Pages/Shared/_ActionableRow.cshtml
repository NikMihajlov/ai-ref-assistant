@model Flourish.Models.Actionable

<div class="flex items-center gap-3 px-5 py-3 group" id="actionable-@Model.Id">
    <input type="checkbox"
           @(Model.IsCompleted ? "checked" : "")
           hx-post="/Goals/Actionables/@Model.Id/Toggle"
           hx-target="#actionable-@Model.Id"
           hx-swap="outerHTML"
           class="w-4 h-4 rounded border-border bg-surface accent-accent cursor-pointer" />
    <span class="text-sm flex-1 @(Model.IsCompleted ? "line-through text-muted" : "text-gray-300")">
        @Model.Title
    </span>
    <button hx-delete="/Goals/Actionables/@Model.Id"
            hx-target="#actionable-@Model.Id"
            hx-swap="outerHTML"
            hx-confirm="Remove this actionable?"
            class="opacity-0 group-hover:opacity-100 text-muted hover:text-red-400 transition-all">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
</div>
