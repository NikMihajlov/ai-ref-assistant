@page
@model Flourish.Pages.Account.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign in — Flourish</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Kumbh+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: { extend: { fontFamily: { sans: ['Kumbh Sans', 'sans-serif'] }, colors: { surface: '#171923', panel: '#1e2130', border: '#2a2f45', accent: '#4ade80' } } }
        }
    </script>
</head>
<body class="bg-surface font-sans flex items-center justify-center min-h-screen">
    <div class="w-full max-w-sm">
        <div class="text-center mb-8">
            <span class="text-accent font-bold text-2xl tracking-tight">Flourish</span>
            <p class="text-gray-500 text-sm mt-1">by GreenCell</p>
        </div>
        <div class="bg-panel border border-border rounded-2xl p-8">
            <h1 class="text-lg font-semibold text-gray-100 mb-1">Welcome back</h1>
            <p class="text-gray-500 text-sm mb-6">Sign in with your GreenCell account</p>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="bg-red-900/30 border border-red-700 text-red-300 text-sm rounded-lg px-4 py-3 mb-4">
                    @Model.ErrorMessage
                </div>
            }

            <a href="/Account/GoogleLogin"
               class="flex items-center justify-center gap-3 w-full bg-white/5 hover:bg-white/10 border border-border rounded-xl px-4 py-3 text-sm text-gray-200 font-medium transition-colors">
                <svg class="w-5 h-5" viewBox="0 0 24 24">
                    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                    <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                </svg>
                Continue with Google
            </a>
        </div>
        <p class="text-center text-xs text-gray-600 mt-6">&copy; @DateTime.Now.Year GreenCell</p>
    </div>
</body>
</html>
